[default]
my_ip = {{ keepalived_data_vip }}
transport_url = rabbit://openstack:{{ rabbitmq_password }}@{{ keepalived_vip }}:5672/
auth_strategy = keystone
# Aumentar o timeout para evitar o erro 500 em máquinas mais lentas
rpc_response_timeout = 60

[database]
connection = postgresql+psycopg2://ironic:{{ ironic_db_password }}@{{ keepalived_cluster_vip }}/ironic

[keystone_authtoken]
www_authenticate_uri = http://{{ keepalived_vip }}:5000/v3
auth_url = http://{{ keepalived_cluster_vip }}:5000/v3
memcached_servers = {{ keepalived_cluster_vip }}:11211
auth_type = password
project_domain_name = Default
user_domain_name = Default
project_name = service
username = ironic
password = {{ ironic_keystone_password }}

[oslo_policy]
# ESTE É O FIX PARA O ERRO 500: Desativa a exigência estrita de system-scope
enforce_scope = false
enforce_new_defaults = false

[ironic_lib]
external_retry_delay = 10
external_retry_count = 30

[deploy]
http_url = http://{{ keepalived_data_vip }}:8088
http_root = /var/lib/ironic/httpboot

[pxe]
tftp_server = {{ keepalived_data_vip }}
tftp_root = /var/lib/ironic/tftpboot

[conductor]
api_url = http://{{ keepalived_vip }}:6385
enabled_hardware_types = idrac,ilo,ipmi,redfish,manual-management
enabled_management_interfaces = idrac,ilo,ipmitool,redfish,fake
enabled_power_interfaces = idrac,ilo,ipmitool,redfish,fake
enabled_inspect_interfaces = idrac,ilo,ipmitool,redfish,no-inspect
enabled_deploy_interfaces = direct,ansible
enabled_vendor_interfaces = idrac,ilo,no-vendor
automated_clean = false
